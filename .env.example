# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/vision_db

# AssemblyAI API Key (FREE: 5 hours/month)
# Get your free API key at: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Gemini AI API Key (for AI analysis/notes generation)
# Get your free API key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Authentication
JWT_SECRET=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Frontend URL
FRONTEND_URL=http://localhost:5173

# File Storage
MAX_UPLOAD_SIZE_MB=100
ALLOWED_AUDIO_FORMATS=mp3,wav,m4a,ogg,webm,flac

# Audio Processing
SEGMENT_DURATION_SECONDS=10

# Environment
ENVIRONMENT=development
